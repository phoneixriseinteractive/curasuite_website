# CuraSuite — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ── Django ─────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=curasuite_dev
DB_USER=curasuite
DB_PASSWORD=curasuite
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── AI Integrations ────────────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Analytics ─────────────────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=
GTM_CONTAINER_ID=
META_PIXEL_ID=

# ── WhatsApp ───────────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER=

# ── CAPTCHA ────────────────────────────────────────────────────────────────────
# Site key is public and lives in the admin panel (Site Settings > CAPTCHA), not here.
# Secret key must never be exposed to the browser, so it lives only in the environment.
# Only the one matching Site Settings > CAPTCHA > Provider is actually used.
RECAPTCHA_SECRET_KEY=
TURNSTILE_SECRET_KEY=
